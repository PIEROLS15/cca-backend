generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CertificateStatus {
  PorFirmar
  PorRecoger
  Entregado
}

enum CertificateRequestStatus {
  EnProceso
  Observado
  Recepcionado
}

enum AssemblyRecordRequestStatus {
  EnProceso
  PorRecoger
  Entregado
}

enum TerrainMeasurementMode {
  RECTANGULAR_AUTO
  AREA_PERIMETER
  MANUAL_TOTAL_AREA
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  fullName  String
  email     String?  @unique
  dni       String?  @unique
  isActive  Boolean  @default(true)
  certificateRangeStart Int?
  certificateRangeEnd   Int?
  lastCertificate       Int?
  roleId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role Role @relation(fields: [roleId], references: [id])

  certificates          Certificate[]
  certificateRequests   CertificateRequest[]
  assemblyRecordRequest AssemblyRecordRequest[]
  documentStatusHistory DocumentStatusHistory[]
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users           User[]
  rolePermissions RolePermission[]
}

model Permission {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       Int
  permissionId Int
  assignedAt   DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Sector {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  certificates Certificate[]
}

model TerrainTypeConfig {
  id                       Int                    @id @default(autoincrement())
  key                      String                 @unique
  label                    String
  formMode                 TerrainMeasurementMode
  showMzLot                Boolean                @default(true)
  allowAdditionalMeasure   Boolean                @default(false)
  allowAreaPerimeterToggle Boolean                @default(false)
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  terrainTypes TerrainType[]
}

model TerrainType {
  id                  Int      @id @default(autoincrement())
  name                String   @unique
  terrainTypeConfigId Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  config       TerrainTypeConfig? @relation(fields: [terrainTypeConfigId], references: [id])
  certificates Certificate[]
}

model Client {
  id             Int      @id @default(autoincrement())
  fullName       String
  documentNumber String   @unique
  address        String?
  phone          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  commoner     Commoner?
  certificates          Certificate[]       @relation("CertificateClient")
  partnerCertificates   Certificate[]       @relation("CertificatePartner")
  certificateRequests   CertificateRequest[]
  partnerRequests       CertificateRequest[] @relation("CertificateRequestPartner")
  assemblyRecordRequests AssemblyRecordRequest[]
  certificateOwners     CertificateOwner[]
}

model Commoner {
  id              Int      @id @default(autoincrement())
  clientId        Int      @unique
  licenseSequence Int?     @unique
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model CertificateRequest {
  id                 Int           @id @default(autoincrement())
  requestNumber      String        @unique
  clientId           Int
  userId             Int?
  partnerId          Int?
  description        String?
  destination        String?
  requestDescription String?
  sectorLocation     String?
  certificateTypes   Json?
  exposure           String?
  attachments        Json?
  legacyPayload      Json?
  status             CertificateRequestStatus @default(EnProceso)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  client  Client  @relation(fields: [clientId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])
  partner Client? @relation("CertificateRequestPartner", fields: [partnerId], references: [id])

  certificates Certificate[]
}

model RequestNumberCounter {
  key       String   @id
  value     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model Certificate {
  id                Int               @id @default(autoincrement())
  certificateNumber String            @unique
  verificationToken String            @unique @default(cuid())
  requestNumber     String
  certificateRequestId Int?
  clientId          Int
  partnerId         Int?
  sectorId          Int
  terrainTypeId     Int
  userId            Int
  width             Decimal?          @db.Decimal(10, 2)
  length            Decimal?          @db.Decimal(10, 2)
  totalArea         Decimal?          @db.Decimal(10, 2)
  area              Decimal?          @db.Decimal(10, 2)
  perimeter         Decimal?          @db.Decimal(10, 2)
  additionalWidth   Decimal?          @db.Decimal(10, 2)
  additionalLength  Decimal?          @db.Decimal(10, 2)
  measurementModeUsed TerrainMeasurementMode @default(RECTANGULAR_AUTO)
  legacyPayload     Json?
  issuedSnapshot    Json?
  mz                String?
  lot               String?
  north             String?
  south             String?
  east              String?
  west              String?
  additionalNotes   String?
  status            CertificateStatus @default(PorFirmar)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  client              Client              @relation("CertificateClient", fields: [clientId], references: [id])
  partner             Client?             @relation("CertificatePartner", fields: [partnerId], references: [id])
  sector              Sector              @relation(fields: [sectorId], references: [id])
  terrainType         TerrainType         @relation(fields: [terrainTypeId], references: [id])
  user                User                @relation(fields: [userId], references: [id])
  certificateRequest  CertificateRequest? @relation(fields: [certificateRequestId], references: [id])
  owners              CertificateOwner[]
  assemblyRecordRequests AssemblyRecordRequest[]
}

model CertificateOwner {
  id            Int      @id @default(autoincrement())
  certificateId Int
  clientId      Int
  order         Int
  source        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  certificate Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  client      Client      @relation(fields: [clientId], references: [id])

  @@unique([certificateId, order])
  @@unique([certificateId, clientId])
  @@index([clientId])
}

model AssemblyRecordRequest {
  id            Int           @id @default(autoincrement())
  code          String        @unique
  clientId      Int
  certificateId Int
  userId        Int?
  description   String?
  buyerFullName String?
  sellerFullName String?
  sectorLocation String?
  terrainType   String?
  awardDate     DateTime?
  possessionTime String?
  email         String?
  phone         String?
  attachments   Json?
  legacyPayload Json?
  status        AssemblyRecordRequestStatus @default(EnProceso)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  client      Client      @relation(fields: [clientId], references: [id])
  certificate Certificate @relation(fields: [certificateId], references: [id])
  user        User?       @relation(fields: [userId], references: [id])
}

model DocumentStatusHistory {
  id              Int      @id @default(autoincrement())
  documentType    String
  documentId      Int
  status          String
  note            String?
  changedByUserId Int?
  changedAt       DateTime @default(now())

  changedBy User? @relation(fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([documentType, documentId, changedAt])
  @@index([documentType, documentId, status])
}
