# Backend
PORT=9001
BACKEND_PORT=9001
JWT_SECRET=secret
FRONTEND_URL=http://localhost:9000

# RENIEC provider selection: codart | decolecta
RENIEC_PROVIDER=codart

# Codart RENIEC
RENIEC_CODART_TOKEN=RENIEC_TOKEN
RENIEC_CODART_URL=https://api-codart.cgrt.org/api/v1/consultas/reniec/dni/

# Decolecta RENIEC
RENIEC_DECOLECTA_TOKEN=RENIEC_TOKEN
RENIEC_DECOLECTA_URL=https://api.decolecta.com/v1/reniec/dni?numero=

# Seeds / sync
API_BASE_URL=http://localhost:9001
SEED_LOGIN_USERNAME=username
SEED_LOGIN_PASSWORD=password
SEED_IMPORTED_USER_PASSWORD=password
FORCE_SEEDS=false

# PostgreSQL / Docker Compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=12345
POSTGRES_DB=comunidad_campesina_asia_db
POSTGRES_PORT=5432

# Prisma
DATABASE_URL=postgresql://postgres:12345@localhost:5432/comunidad_campesina_asia_db?schema=public
